# Environment variables for multi-cloud GraphRAG
# Copy this file to .env and fill in your actual values.
# Never commit .env to version control.

# =============================================================================
# AWS S3 (Primary Storage)
# =============================================================================
AWS_PROFILE=your-aws-profile
AWS_DEFAULT_REGION=ap-south-1
# Explicit credentials (use only if not relying on a named profile or instance role)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# S3 bucket name (set in config/storage/aws_s3.yml; override here if needed)
# S3_BUCKET_NAME=your-bucket-name

# =============================================================================
# Azure Blob Storage (Fallback)
# =============================================================================
# Full connection string — obtain from:
#   az storage account show-connection-string --name <account> --resource-group <rg>
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=YOUR_ACCOUNT_NAME;AccountKey=YOUR_ACCOUNT_KEY;EndpointSuffix=core.windows.net

AZURE_STORAGE_ACCOUNT=your-storage-account-name
AZURE_STORAGE_RESOURCE_GROUP=your-resource-group-name

# =============================================================================
# Azure Active Directory (Optional — for RBAC auth instead of connection string)
# =============================================================================
# AZURE_TENANT_ID=
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=
# AZURE_WORKSPACE_ID=

# =============================================================================
# Application Settings
# =============================================================================
GRAPHRAG_ENV=development
LOG_LEVEL=INFO

# =============================================================================
# Cost Tracking (Optional)
# =============================================================================
# DAILY_BUDGET_USD=10
# MONTHLY_BUDGET_USD=50

