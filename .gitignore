# ─── Generated data (Docker volumes + pipeline outputs) ───────────────────────
# Each subdirectory has a .gitkeep to preserve the folder structure.
# Do NOT use `data/` — that ignores the directory itself and breaks negations.
data/artifacts/**
data/models/**
data/neo4j/**
data/pdfs/**
data/qdrant/**
data/temporal/**
!data/artifacts/.gitkeep
!data/models/.gitkeep
!data/neo4j/.gitkeep
!data/pdfs/.gitkeep
!data/qdrant/.gitkeep
!data/temporal/.gitkeep

