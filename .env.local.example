# ── LLM Inference ─────────────────────────────────────────────────────────
# Production (Ubuntu + NVIDIA L4): use SGLang served by core-llm-inference
# Run: core-llm-inference serve --model Qwen/Qwen2.5-7B-Instruct --detach
SGLANG_BASE_URL=http://localhost:30000/v1

# Dev (macOS): LM Studio — OpenAI-compatible, JSON mode, no external deps
# LM Studio: install from https://lmstudio.ai, load a GGUF model, enable server (port 1234)
# LLM_PROVIDER=lmstudio
# LM_STUDIO_BASE_URL=http://localhost:1234/v1
# LLM_MODEL=lmstudio-community/Qwen2.5-7B-Instruct-GGUF
# LLM_EMBED_MODEL=nomic-embed-text:latest

# Ollama alternative (dev only — not recommended on CUDA prod servers)
# LLM_PROVIDER=ollama
# LLM_BASE_URL=http://localhost:11434
# LLM_MODEL=qwen3:8b

# ── Graph Store ────────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=testpassword

# ── Vector Store ───────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333

# ── Storage Paths ──────────────────────────────────────────────────────────
DATA_DIR=./data
PDF_INPUT_DIR=./data/pdfs
ARTIFACTS_DIR=./data/artifacts

# ── API Server (agentic-reasoning FastAPI) ─────────────────────────────────
REASONING_API_HOST=0.0.0.0
REASONING_API_PORT=8000

# ── UI (Next.js) ───────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_USE_MOCK=false
