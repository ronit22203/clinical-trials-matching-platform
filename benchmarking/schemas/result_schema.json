{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Benchmark Run Results Schema",
  "description": "Validates all benchmark output files produced by the evaluation harness",
  "definitions": {
    "ci_bound": {
      "type": "object",
      "required": ["lower", "upper", "confidence"],
      "properties": {
        "lower": {"type": "number", "minimum": 0, "maximum": 1},
        "upper": {"type": "number", "minimum": 0, "maximum": 1},
        "confidence": {"type": "number", "minimum": 0, "maximum": 1}
      }
    },
    "metric_with_ci": {
      "type": "object",
      "required": ["value", "ci"],
      "properties": {
        "value": {"type": "number", "minimum": 0, "maximum": 1},
        "ci": {"$ref": "#/definitions/ci_bound"}
      }
    },
    "percentile_stats": {
      "type": "object",
      "required": ["p50", "p95", "p99"],
      "properties": {
        "p50": {"type": "number"},
        "p95": {"type": "number"},
        "p99": {"type": "number"}
      }
    }
  },
  "retrieval_schema": {
    "type": "object",
    "required": ["run_id", "timestamp", "config", "aggregate", "per_query"],
    "properties": {
      "run_id": {"type": "string"},
      "timestamp": {"type": "string", "format": "date-time"},
      "config": {
        "type": "object",
        "required": ["collection", "embedding_model", "top_k", "bootstrap_resamples"],
        "properties": {
          "collection": {"type": "string"},
          "embedding_model": {"type": "string"},
          "top_k": {"type": "integer", "minimum": 1, "maximum": 100},
          "bootstrap_resamples": {"type": "integer", "minimum": 100}
        }
      },
      "aggregate": {
        "type": "object",
        "required": ["recall_at_1", "recall_at_3", "recall_at_5", "recall_at_10",
                     "precision_at_5", "ndcg_at_5", "mrr", "hit_rate_at_5"],
        "properties": {
          "recall_at_1": {"$ref": "#/definitions/metric_with_ci"},
          "recall_at_3": {"$ref": "#/definitions/metric_with_ci"},
          "recall_at_5": {"$ref": "#/definitions/metric_with_ci"},
          "recall_at_10": {"$ref": "#/definitions/metric_with_ci"},
          "precision_at_5": {"$ref": "#/definitions/metric_with_ci"},
          "ndcg_at_5": {"$ref": "#/definitions/metric_with_ci"},
          "mrr": {"$ref": "#/definitions/metric_with_ci"},
          "hit_rate_at_5": {"$ref": "#/definitions/metric_with_ci"}
        }
      },
      "per_query": {
        "type": "array",
        "items": {
          "type": "object",
          "required": ["query_id", "category", "retrieved_chunks", "recall_at_5",
                       "precision_at_5", "ndcg_at_5", "rr"],
          "properties": {
            "query_id": {"type": "string"},
            "category": {"type": "string"},
            "retrieved_chunks": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["rank", "chunk_index", "score", "relevance_grade"],
                "properties": {
                  "rank": {"type": "integer"},
                  "chunk_index": {"type": "integer"},
                  "score": {"type": "number"},
                  "relevance_grade": {"type": "integer", "enum": [0, 1, 2]}
                }
              }
            },
            "recall_at_5": {"type": "number"},
            "precision_at_5": {"type": "number"},
            "ndcg_at_5": {"type": "number"},
            "rr": {"type": "number"}
          }
        }
      }
    }
  },
  "extraction_schema": {
    "type": "object",
    "required": ["run_id", "timestamp", "entity_metrics", "relation_metrics",
                 "predicted_entity_count", "golden_entity_count",
                 "predicted_relation_count", "golden_relation_count"],
    "properties": {
      "run_id": {"type": "string"},
      "timestamp": {"type": "string", "format": "date-time"},
      "entity_metrics": {
        "type": "object",
        "required": ["exact", "relaxed"],
        "properties": {
          "exact": {
            "type": "object",
            "required": ["precision", "recall", "f1"],
            "properties": {
              "precision": {"type": "number"},
              "recall": {"type": "number"},
              "f1": {"type": "number"}
            }
          },
          "relaxed": {
            "type": "object",
            "required": ["precision", "recall", "f1"],
            "properties": {
              "precision": {"type": "number"},
              "recall": {"type": "number"},
              "f1": {"type": "number"}
            }
          }
        }
      },
      "relation_metrics": {
        "type": "object",
        "required": ["strict", "relaxed"],
        "properties": {
          "strict": {
            "type": "object",
            "required": ["precision", "recall", "f1"],
            "properties": {
              "precision": {"type": "number"},
              "recall": {"type": "number"},
              "f1": {"type": "number"}
            }
          },
          "relaxed": {
            "type": "object",
            "required": ["precision", "recall", "f1"],
            "properties": {
              "precision": {"type": "number"},
              "recall": {"type": "number"},
              "f1": {"type": "number"}
            }
          }
        }
      }
    }
  },
  "inference_schema": {
    "type": "object",
    "required": ["run_id", "timestamp", "num_runs", "queries_per_run",
                 "ttft_ms", "tpot_ms", "throughput_toks_per_sec", "failure_count"],
    "properties": {
      "run_id": {"type": "string"},
      "timestamp": {"type": "string", "format": "date-time"},
      "num_runs": {"type": "integer"},
      "queries_per_run": {"type": "integer"},
      "ttft_ms": {"$ref": "#/definitions/percentile_stats"},
      "tpot_ms": {"$ref": "#/definitions/percentile_stats"},
      "throughput_toks_per_sec": {
        "type": "object",
        "required": ["mean", "std"],
        "properties": {
          "mean": {"type": "number"},
          "std": {"type": "number"}
        }
      },
      "failure_count": {"type": "integer", "minimum": 0}
    }
  }
}
