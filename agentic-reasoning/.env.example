# LLM inference provider (required)
# Supported values: lmstudio, ollama, sglang
LLM_PROVIDER=lmstudio

# LM Studio (default — OpenAI-compatible server, enforces JSON mode)
# Install: https://lmstudio.ai  |  Start server on port 1234
LM_STUDIO_BASE_URL=http://localhost:1234/v1
LLM_MODEL=lmstudio-community/Qwen2.5-7B-Instruct-GGUF

# Ollama (alternative — set LLM_PROVIDER=ollama)
# LLM_BASE_URL=http://localhost:11434
# LLM_MODEL=qwen3:8b

# SGLang (alternative — set LLM_PROVIDER=sglang)
# SGLANG_BASE_URL=http://localhost:30000/v1

# OpenFDA (optional) — higher rate limits with an API key
# Get one at: https://open.fda.gov/apis/authentication/
OPENFDA_API_KEY=your_openfda_api_key_here
